# === DATABASE ===
# Connection string dari Supabase (Project Settings -> Database -> Connection String)
# Format: postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require"
# Direct connection for Prisma Migrations
DIRECT_URL="postgresql://postgres:your-password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres"

# === AI ===
# Dapatkan API key dari https://openrouter.ai
OPENROUTER_API_KEY="sk-or-v1-REPLACE-WITH-YOUR-API-KEY"

# === AUTH ===
# Generate dengan: openssl rand -base64 32
SESSION_SECRET="your-secret-key-here"
